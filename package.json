{
  "name": "open-deep-research",
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "tsx": "tsx --env-file-if-exists=.env.local",
    "start": "tsx --env-file-if-exists=.env.local src/run.ts",
    "server": "tsx --env-file-if-exists=.env.local src/server/index.ts",
    "dev:server": "tsx watch --env-file-if-exists=.env.local src/server/index.ts",
    "dev:web": "cd web && npx vite",
    "dev": "npm run dev:server & npm run dev:web",
    "build:web": "cd web && npx vite build",
    "api": "tsx --env-file-if-exists=.env.local src/api.ts",
    "docker": "tsx src/run.ts",
    "test": "node --test src/**/*.test.ts"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.13.0",
    "@types/uuid": "^9.0.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@ai-sdk/fireworks": "^0.1.14",
    "@ai-sdk/openai": "^1.1.9",
    "@tavily/core": "^0.0.2",
    "ai": "^4.1.17",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "duck-duck-scrape": "^2.2.7",
    "express": "^4.18.3",
    "js-tiktoken": "^1.0.17",
    "lodash-es": "^4.17.21",
    "md-to-pdf": "^5.2.5",
    "p-limit": "^6.2.0",
    "uuid": "^9.0.1",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": "22.x"
  }
}
