TAVILY_API_KEY="YOUR_KEY"
# TAVILY_CONCURRENCY="2"

OPENAI_KEY="YOUR_KEY"
CONTEXT_SIZE="128000"

# If you want to use other OpenAI compatible API, add the following below:
# OPENAI_ENDPOINT="http://localhost:11434/v1"
# CUSTOM_MODEL="llama3.1"

# If you want to use fireworks.ai's DeepSeek R1 model:
# FIREWORKS_KEY="YOUR_KEY"

# SearXNG (free, self-hosted alternative to Tavily):
# If no TAVILY_API_KEY is set, the system auto-detects and uses SearXNG.
# SEARXNG_URL="http://localhost:8080"

# Multi-model: use a cheaper model for extraction/summarization tasks.
# Leave empty to use the primary model for everything (default).
# FAST_MODEL=""
# FAST_MODEL_ENDPOINT=""

# NOTE: All settings above can also be configured via the web UI
# at http://localhost:3051/settings when running the web app.
# Web UI settings are saved to data/settings.json and take priority.
